# ============================================
# 多Agent智能会议助手系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# ---------- LLM API ----------
# 智谱 AI (推荐)
ZHIPUAI_API_KEY=your_zhipu_api_key_here
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPUAI_MODEL=glm-4-flash

# OpenAI API (备选)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ---------- 语音转写 ----------
# SenseVoice(FunASR) 配置
ASR_MODEL_ID=iic/SenseVoiceSmall
ASR_LANGUAGE=zh
ASR_DEVICE=cuda

# ---------- Jira 集成 ----------
JIRA_SERVER=https://your-company.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=MEET

# ---------- 飞书集成 ----------
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token

# ---------- 数据库 ----------
DATABASE_URL=postgresql://postgres:password@localhost:5432/meeting_assistant
REDIS_URL=redis://localhost:6379/0

# ---------- 服务配置 ----------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WEBSOCKET_PORT=8001
LOG_LEVEL=INFO
